# KDA-optimized diffusion kernels overlay for SGLang
# ===================================================
#
# Apply from inside the sglang repository root with:
#
#   git apply /path/to/kernel-pilot/patches/sglang_kda_kernels.patch
#
# Activation requires:
#
#   export PYTHONPATH=/path/to/kernel-pilot:$PYTHONPATH
#
# The patch appends a small overlay block to the end of
# `python/sglang/__init__.py`. The hunk context is the last three lines of
# `__all__`, which makes the patch survive most upstream edits to earlier
# parts of `__init__.py`. If the patch refuses cleanly because upstream
# rewrote the tail of `__init__.py`, regenerate it from the current sglang
# HEAD as documented in `patches/README.md`.

--- a/python/sglang/__init__.py
+++ b/python/sglang/__init__.py
@@ -114,3 +114,19 @@
     "global_config",
     "__version__",
 ]
+
+# ---------------------------------------------------------------------
+# kda_kernels overlay (kernel-pilot output)
+# ---------------------------------------------------------------------
+# When `kda_kernels` is importable (i.e. kernel-pilot/ is on PYTHONPATH)
+# this block transparently swaps in every KDA-promoted diffusion kernel.
+# Functions still on the SGLang baseline keep their original
+# implementation. Failure to import `kda_kernels` is silent so the
+# unpatched / unconfigured case is identical to upstream.
+try:
+    import kda_kernels as _kda_kernels
+    _kda_kernels.install()
+except ImportError:
+    pass
+except Exception as _kda_e:  # noqa: BLE001
+    import warnings
+    warnings.warn(f"kda_kernels.install() failed: {_kda_e!r}")
