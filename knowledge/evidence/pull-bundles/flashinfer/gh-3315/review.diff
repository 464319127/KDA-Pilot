+-subdir('src')
+-if get_option('build_tests') and get_option('buildtype') != 'release'
+-  subdir('test')
++if not get_option('nixl_ep_only')
++    subdir('src')
++    if get_option('build_tests') and get_option('buildtype') != 'release'
++        subdir('test')
++    endif
+ endif
