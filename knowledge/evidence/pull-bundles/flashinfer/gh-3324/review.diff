+    old_B = torch.randn(cache_size, 2, T, ngroups, d_state, device=device, dtype=dtype)
+    old_dt = torch.zeros(cache_size, 2, nheads, T, device=device, dtype=torch.float32)
+    old_cumAdt = torch.zeros(
