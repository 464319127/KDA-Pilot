+            HAS_CACHE_BATCH_INDICES=HAS_CACHE_BATCH_INDICES,
+            LAUNCH_WITH_PDL=launch_with_pdl,
+            LAUNCH_DEPENDENT_KERNELS=use_internal_pdl,
