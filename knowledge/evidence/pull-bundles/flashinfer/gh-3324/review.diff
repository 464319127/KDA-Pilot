+    n = offsets.numel()
+    out = torch.empty((n, 4), dtype=torch.int32, device="cuda")
+    BLOCK_SIZE = 1024
+    grid = ((n + BLOCK_SIZE - 1) // BLOCK_SIZE,)
+    _triton_philox4x_offsets_kernel[grid](out, seed_t, offsets, n, n_rounds, BLOCK_SIZE)
+    return out
+
