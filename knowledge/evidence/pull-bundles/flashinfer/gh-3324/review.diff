+
+    slot_indices = (
+        state_batch_indices.tolist() if paged_cache else list(range(cache_size))
+    )
+    slots_idx = state_batch_indices if paged_cache else slice(None)
+    old_x[slots_idx, :npredicted] = x1
+    for i, slot in enumerate(slot_indices):
