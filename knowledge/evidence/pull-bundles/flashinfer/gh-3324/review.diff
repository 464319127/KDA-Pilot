+                state_scales.stride(1),
+                state_scales.stride(2),
+            )
+        else:
+            state_scales_arg = state  # any valid ptr — gated by QUANT_MAX==0
+            state_scales_strides = (0, 0, 0)
+
+        _checkpointing_main_kernel[grid](
