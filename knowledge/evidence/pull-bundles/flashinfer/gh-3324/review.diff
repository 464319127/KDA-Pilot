+    input_dtype: torch.dtype,
+    dt_dtype: torch.dtype,
+    weight_dtype: torch.dtype,
+    matrixA_dtype: torch.dtype,
+    stateIndex_dtype: torch.dtype,
+    dim: int,
+    dstate: int,
+    npredicted: int,
+    max_window: int,
+    heads_per_group: int,
+) -> None:
+    """Internal function registered with torch.library for torch.compile() support."""
+    module = _get_module(
+        state_dtype,
+        input_dtype,
+        dt_dtype,
+        weight_dtype,
+        matrixA_dtype,
