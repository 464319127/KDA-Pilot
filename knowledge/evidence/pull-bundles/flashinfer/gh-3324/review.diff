+    rand_seed: Optional[torch.Tensor],
+    d_split: int,
+    cu_seqlens: Optional[torch.Tensor],
+    enable_pdl: bool,
+    philox_rounds: int,
+    state_dtype: torch.dtype,
+    input_dtype: torch.dtype,
+    dt_dtype: torch.dtype,
+    weight_dtype: torch.dtype,
