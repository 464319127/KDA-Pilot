+        test_out = torch.zeros(
+            batch, npredicted, nheads, head_dim, device=device, dtype=dtype
+        )
+        old_x_test = old_x.clone()
+        old_B_test = old_B.clone()
+        old_dt_test = old_dt.clone()
+        old_dA_test = old_dA_cumsum.clone()
+        checkpointing_ssu(
+            test_state,
+            old_x_test,
+            old_B_test,
+            old_dt_test,
+            old_dA_test,
+            cache_buf_idx.clone(),
+            test_prev,
+            x=x2,
+            dt=dt2,
+            A=A,
+            B=B2,
+            C=C2,
+            out=test_out,
+            D=D,
+            dt_bias=dt_bias,
