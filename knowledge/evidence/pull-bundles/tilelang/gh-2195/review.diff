+/**
+ * hipJitOption
+ */
+typedef enum hipJitOption {
+  hipJitOptionMaxRegisters = 0,         ///< CUDA Only Maximum registers may be used in a thread,
+                                        ///< passed to compiler
+  hipJitOptionThreadsPerBlock,          ///< CUDA Only Number of thread per block
