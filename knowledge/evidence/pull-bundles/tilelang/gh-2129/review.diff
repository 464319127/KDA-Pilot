+TL_DEVICE void tma_load_gather4(const CUtensorMap &descriptor,
+                                BarrierType &smem_mbar,
+                                void const *const smem_ptr, int32_t const &col,
+                                int32_t const &r0, int32_t const &r1,
+                                int32_t const &r2, int32_t const &r3) {
