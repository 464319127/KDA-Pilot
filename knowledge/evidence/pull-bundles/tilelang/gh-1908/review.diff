+    np.testing.assert_allclose(
+        B.cpu().numpy(),
+        A.cpu().numpy(),
+        rtol=0,
+        atol=0,
+        err_msg="tma_store_cluster copy produced wrong result",
+    )
+
+
+@tilelang.testing.requires_cuda
