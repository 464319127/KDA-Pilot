+            T.warpgroup_fence_operand(C_buf, num_regs=accum_regs)
+
+        return _warp_mma(A_ptr, B_ptr, C_buf)
+
+    def wgmma_rs(
+        self,
+        A_region: BufferRegion,
+        E_region: BufferRegion,
