+        warp_rows, warp_cols = self.warp_rows, self.warp_cols
+        micro_size_k = self.micro_size_k
+        k_dim, n_dim = self.warp_k, self.block_col_warps * self.warp_col_tiles
+        wgmma_prefix = self.wgmma_prefix
