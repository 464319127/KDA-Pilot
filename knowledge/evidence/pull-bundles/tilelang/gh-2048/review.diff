+                            E_local.data,
+                            e_local_offset,
+                            self.SPARSE_SELECTOR,
+                            desc_b.data,
+                            (B_offset * elems_in_bytes) >> 4,
+                            C_buf.data,
+                            C_offset,
+                            scale_out,
+                            scale_in_a,
+                            scale_in_b,
