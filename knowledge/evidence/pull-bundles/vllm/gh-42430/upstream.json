    "title": "[Bugfix] mamba: run single-token extends as decodes",
    "user": {
      "login": "netanel-haber",
      "id": 58652339,
      "node_id": "MDQ6VXNlcjU4NjUyMzM5",
      "avatar_url": "https://avatars.githubusercontent.com/u/58652339?v=4",
      "gravatar_id": "",
