      "starred_url": "https://api.github.com/users/netanel-haber/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/netanel-haber/subscriptions",
      "organizations_url": "https://api.github.com/users/netanel-haber/orgs",
      "repos_url": "https://api.github.com/users/netanel-haber/repos",
      "events_url": "https://api.github.com/users/netanel-haber/events{/privacy}",
