    "title": "[Perf] Add do_not_specialize in fused FP8 RoPE kernel",
    "user": {
      "login": "xyang16",
      "id": 105740670,
      "node_id": "U_kgDOBk15fg",
      "avatar_url": "https://avatars.githubusercontent.com/u/105740670?v=4",
      "gravatar_id": "",
