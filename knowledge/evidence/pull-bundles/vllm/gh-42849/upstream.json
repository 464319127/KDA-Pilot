      "html_url": "https://github.com/xyang16",
      "followers_url": "https://api.github.com/users/xyang16/followers",
      "following_url": "https://api.github.com/users/xyang16/following{/other_user}",
      "gists_url": "https://api.github.com/users/xyang16/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/xyang16/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/xyang16/subscriptions",
      "organizations_url": "https://api.github.com/users/xyang16/orgs",
      "repos_url": "https://api.github.com/users/xyang16/repos",
      "events_url": "https://api.github.com/users/xyang16/events{/privacy}",
