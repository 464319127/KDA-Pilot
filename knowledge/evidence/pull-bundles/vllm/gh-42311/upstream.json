    "locked": false,
    "title": "[Model] [Perf] Use flatten for Qwen3.5's GDN output projection",
    "user": {
      "login": "rishaps",
      "id": 215205492,
      "node_id": "U_kgDODNPGdA",
      "avatar_url": "https://avatars.githubusercontent.com/u/215205492?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/rishaps",
      "html_url": "https://github.com/rishaps",
      "followers_url": "https://api.github.com/users/rishaps/followers",
      "following_url": "https://api.github.com/users/rishaps/following{/other_user}",
      "gists_url": "https://api.github.com/users/rishaps/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/rishaps/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/rishaps/subscriptions",
      "organizations_url": "https://api.github.com/users/rishaps/orgs",
      "repos_url": "https://api.github.com/users/rishaps/repos",
      "events_url": "https://api.github.com/users/rishaps/events{/privacy}",
      "received_events_url": "https://api.github.com/users/rishaps/received_events",
