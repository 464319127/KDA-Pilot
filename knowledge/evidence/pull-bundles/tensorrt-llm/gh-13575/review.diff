+    assert rebuild_src.count("indexer_k_dtype=indexer_k_dtype") >= 2, (
+        "ModelConfig.from_pretrained DeepseekV4ForCausalLM branch must "
+        "forward indexer_k_dtype to DeepSeekV4SparseAttentionConfig(...)."
+    )
