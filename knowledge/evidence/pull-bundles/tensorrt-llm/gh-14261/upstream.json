    "title": "[https://nvbugs/6185234][fix] DeepSeek-V3.2 tokenizer load on transformers 5.x",
    "user": {
      "login": "Hudayday",
      "id": 32944717,
      "node_id": "MDQ6VXNlcjMyOTQ0NzE3",
      "avatar_url": "https://avatars.githubusercontent.com/u/32944717?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Hudayday",
      "html_url": "https://github.com/Hudayday",
      "followers_url": "https://api.github.com/users/Hudayday/followers",
      "following_url": "https://api.github.com/users/Hudayday/following{/other_user}",
      "gists_url": "https://api.github.com/users/Hudayday/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Hudayday/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Hudayday/subscriptions",
      "organizations_url": "https://api.github.com/users/Hudayday/orgs",
      "repos_url": "https://api.github.com/users/Hudayday/repos",
      "events_url": "https://api.github.com/users/Hudayday/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Hudayday/received_events",
      "type": "User",
      "user_view_type": "public",
