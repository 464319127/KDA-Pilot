    "title": "[AMD] Bump amd/Kimi-K2.5-MXFP4 revision to align with shared-experts fusion",
    "user": {
      "login": "yctseng0211",
      "id": 238155574,
      "node_id": "U_kgDODjH3Ng",
      "avatar_url": "https://avatars.githubusercontent.com/u/238155574?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/yctseng0211",
