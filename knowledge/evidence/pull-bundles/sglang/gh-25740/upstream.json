      "starred_url": "https://api.github.com/users/yctseng0211/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/yctseng0211/subscriptions",
      "organizations_url": "https://api.github.com/users/yctseng0211/orgs",
      "repos_url": "https://api.github.com/users/yctseng0211/repos",
      "events_url": "https://api.github.com/users/yctseng0211/events{/privacy}",
      "received_events_url": "https://api.github.com/users/yctseng0211/received_events",
