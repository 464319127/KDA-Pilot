    "title": "[Gemma4]: Fix FP8 Triton scale layout",
    "user": {
      "login": "Ratish1",
      "id": 114130421,
      "node_id": "U_kgDOBs199Q",
      "avatar_url": "https://avatars.githubusercontent.com/u/114130421?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/Ratish1",
      "html_url": "https://github.com/Ratish1",
      "followers_url": "https://api.github.com/users/Ratish1/followers",
      "following_url": "https://api.github.com/users/Ratish1/following{/other_user}",
      "gists_url": "https://api.github.com/users/Ratish1/gists{/gist_id}",
      "starred_url": "https://api.github.com/users/Ratish1/starred{/owner}{/repo}",
      "subscriptions_url": "https://api.github.com/users/Ratish1/subscriptions",
      "organizations_url": "https://api.github.com/users/Ratish1/orgs",
      "repos_url": "https://api.github.com/users/Ratish1/repos",
      "events_url": "https://api.github.com/users/Ratish1/events{/privacy}",
      "received_events_url": "https://api.github.com/users/Ratish1/received_events",
      "type": "User",
