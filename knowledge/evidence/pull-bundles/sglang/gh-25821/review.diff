-def sparse_mla_fwd_decode_partial(
-    heads,
-    dim,
-    tail_dim,
-    topk,
-    *,
-    kv_group=1,
-    sm_scale=None,
-    is_causal=True,
-    block_I=64,
-    inner_iter=1,
-    num_stages=1,
-    threads=256,
