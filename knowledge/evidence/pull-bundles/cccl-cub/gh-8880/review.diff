+{
+  constexpr unsigned int target_block_size = c2h::get<0, TestType>::value;
+  auto d_in                                = c2h::device_vector<int>{0, 0, 1, 1, 2, 2, 3, 3};
+  auto d_out                               = c2h::device_vector<int>(8);
+  auto d_num_selected                      = c2h::device_vector<unsigned int>(1);
